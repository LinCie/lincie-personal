---
// src/components/content/ProjectBand.astro
// Exhibition-style project band. Static structure only.
// Hero image reveal added in Story 5.4. Hover animation added in Story 3.5.

interface Props {
  title: string;
  slug: string;
  date: string;
  disciplines: string[];
  heroImage?: string;
}

const { title, slug, date, disciplines, heroImage } = Astro.props;

const metaLine = `${date.slice(0, 4)}${disciplines.length > 0 ? ` — ${disciplines.join(", ")}` : ""}`;
---

<article class="group">
  <a
    href={`/projects/${slug}`}
    class="block items-start md:grid md:min-h-[30vh] md:grid-cols-[1fr_40%]"
  >
    <!-- Left: title + meta.
         items-start on the grid container prevents this div from stretching
         to fill the full min-h-[30vh] height when content is short. -->
    <div class="py-7 md:py-14">
      <h2
        transition:name={`project-title-${slug}`}
        class="text-ink relative font-serif leading-[1.05] font-normal"
        style="font-size: clamp(2.5rem, 6.5vw, 4.25rem);"
      >
        {title}
      </h2>
      <p class="text-meta mt-7 font-mono text-[0.75rem]">
        {metaLine}
      </p>
    </div>

    <!-- Right: hero image — fades in on band hover/focus (Story 5.4) -->
    <div class="hidden md:block" aria-hidden="true">
      {
        heroImage && (
          <img
            src={heroImage}
            alt=""
            aria-hidden="true"
            class="h-full w-full object-cover"
          />
        )
      }
    </div>
  </a>
</article>

<style>
  /* Inkstroke underline on project title — draws on band hover/focus.
     Thicker (2px) than InlineLink (1px) because display-size type needs
     proportionally heavier stroke weight for visual balance. */
  h2::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--ink);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 250ms var(--ease-mark);
  }

  /* group hover/focus propagation from the parent <article class="group">.
     :global(.group) prevents Astro from adding the data-astro-cid attribute
     to the .group selector — Tailwind utility classes are not scoped.
     The h2::after part IS scoped (correct — targets only this component's h2).
     :focus-within (not :focus-visible) because the focusable <a> is a child
     of <article>; the article itself is not focusable. */
  :global(.group):hover h2::after,
  :global(.group):focus-within h2::after {
    transform: scaleX(1);
  }

  /* Hero image — starts hidden, fades in on band hover/focus */
  img {
    opacity: 0;
    transition: opacity 250ms var(--ease-mark);
  }

  /* Hero image reveal — opacity only, same timing as inkstroke underline */
  :global(.group):hover img,
  :global(.group):focus-within img {
    opacity: 0.35;
  }

  /* Forced-colors (Windows High Contrast): hide custom pseudo-element.
     System handles link styling; prevents phantom layout element. */
  @media (forced-colors: active) {
    h2::after {
      display: none;
    }
    img {
      display: none;
    }
  }
</style>
